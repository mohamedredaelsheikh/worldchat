name: ahlachat
description: A new Flutter project.

# The following line prevents the package from being accidentally published to
# pub.dev using `flutter pub publish`. This is preferred for private packages.
publish_to: 'none' # Remove this line if you wish to publish to pub.dev

# The following defines the version and build number for your application.
# A version number is three numbers separated by dots, like 1.2.43
# followed by an optional build number separated by a +.
# Both the version and the builder number may be overridden in flutter
# build by specifying --build-name and --build-number, respectively.
# In Android, build-name is used as versionName while build-number used as versionCode.
# Read more about Android versioning at https://developer.android.com/studio/publish/versioning
# In iOS, build-name is used as CFBundleShortVersionString while build-number used as CFBundleVersion.
# Read more about iOS versioning at
# https://developer.apple.com/library/archive/documentation/General/Reference/InfoPlistKeyReference/Articles/CoreFoundationKeys.html
version: 1.0.111+111
environment:
  sdk: ">=2.16.2 <3.0.0"
 
# Dependencies specify other packages that your package needs in order to work.
# To automatically upgrade your package dependencies to the latest versions
# consider running `flutter pub upgrade --major-versions`. Alternatively,
# dependencies can be manually updated by changing the version numbers below to
# the latest version available on pub.dev. To see which dependencies have newer
# versions available, run `flutter pub outdated`.
dependencies:
  flutter:
    sdk: flutter


  # The following adds the Cupertino Icons font to your application.
  # Use with the CupertinoIcons class for iOS style icons.
  cupertino_icons: ^1.0.2
  http:
  timer_count_down: ^2.2.2
  roulette:
  google_fonts: ^3.0.1
  flutter_local_notifications: ^9.6.0
  sentry_flutter:
  get_ip_address: ^0.0.5
  popover:
  slider_controller: ^0.0.4
  auto_size_text: ^3.0.0
  readmore:
  badges:
  cherry_toast: ^1.0.9
  flutter_sound: ^9.2.13
  flutter_mentions:
  flutter_jailbreak_detection: ^1.10.0
  lottie:
  palestine_trusted_device: ^0.1.1
  flutter_fortune_wheel: ^1.2.0
  device_info_plus: 3.2.4

  package_info_plus:
  connectivity_plus:
  new_version_plus: any
  pull_to_refresh: ^2.0.0
  animate_do: ^2.1.0
  fluttertoast:
  animated_overflow:
  in_app_update:
  provider:
  circular_countdown: ^2.1.0
  flutter_custom_clippers: ^2.0.0
  marquee:
  photo_view: ^0.14.0
  image_downloader: ^0.31.0
  wakelock: ^0.6.2
  timeago: ^3.2.2
  shared_preferences:
  font_awesome_flutter: ^10.1.0
  video_player:
  flutter_circle_color_picker: ^0.3.0
  flutter_keyboard_visibility: ^5.3.0
  spring: ^2.0.2
  dio:
  carousel_slider: ^4.1.1
  firebase_auth: ^3.3.20
  path_provider: ^2.0.11
  simple_timer: ^2.0.0
  webview_flutter: ^3.0.4
  google_sign_in: any
  image_picker:
  pin_code_fields: ^7.4.0
  delayed_display: ^2.0.0
  flutter_native_splash:
  country_picker: ^2.0.16
  flutter_image_slideshow: ^0.1.2
  declarative_refresh_indicator: ^0.1.0
  svgaplayer_flutter: ^2.1.2
  avatar_glow: ^2.0.2
  animated_text_kit:
  firebase_messaging: any
  on_audio_query: ^2.6.0
  draggable_widget: ^2.0.0
  just_audio: ^0.9.20
  audio_video_progress_bar: ^0.10.0
  rxdart: ^0.27.3
  pusher_channels:
  purchases_flutter: ^4.4.1
  country_code_picker:
  country_list_pick: ^1.0.1+6
  tab_indicator_styler: ^2.0.0
  url_launcher:
  cached_network_image: ^3.2.0
  pusher_client:
  flutter_svg: any
  agora_rtc_engine: 5.1.0
  permission_handler: any
  percent_indicator: 4.0.1
  filling_slider:
  zoom_pinch_overlay: ^1.3.2
  flutter_facebook_auth:
  country_calling_code_picker: ^2.0.1
  firebase_core_platform_interface: 4.5.1
  flutter_smart_dialog:
  image_cropper: ^3.0.1
  banner_carousel: ^1.2.1
  wp_pivot_flutter: ^1.0.0
  firebase_app_check: ^0.0.9+1
  motion_toast:
dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_localizations:
    sdk: flutter
  # The "flutter_lints" package below contains a set of recommended lints to
  # encourage good coding practices. The lint set provided by the package is
  # activated in the `analysis_options.yaml` file located at the root of your
  # package. See that file for information about deactivating specific lint
  # rules and activating additional ones.
flutter_native_splash:
  image: assets/image/worldLogo.png
  color: "#c7ebff"
  android12: true
  android_12:
    image: assets/image/worldLogo.png
#animated_Buttom_Navigation_baassets/image/AppLogo.pngr: ^0.3.3

# For information on the generic Dart part of this file, see the
# following page: https://dart.dev/tools/pub/pubspec

# The following section is specific to Flutter.
flutter:
  # The following line ensures that the Material Icons font is
  # included with your application, so that you can use the icons in
  # the material Icons class.
  uses-material-design: true

  # To add assets to your application, add an assets section, like this:
  assets:
    - assets/image/
    - assets/language/
    - assets/audios/
  fonts:
    - family: cairo
      fonts:
        - asset: assets/font/Cairo-VariableFont_wght.ttf
          weight: 400
    - family: NotoSans
      fonts:
        - asset: assets/font/Noto-Sans-700.ttf
          weight: 400

    - family: numbers
      fonts:
        - asset: assets/font/DancingScript-Medium.ttf
          weight: 400
    - family: anton
      fonts:
        - asset: assets/font/DancingScript-Medium.ttf
          weight: 400
    - family: Metal
      fonts:
        - asset: assets/font/MetalMania-Regular.ttf
          weight: 400
    - family: Omar
      fonts:
        - asset: assets/font/Omar-Bold-1.ttf
          weight: 400
    - family: OmarR
      fonts:
        - asset: assets/font/DIN-CondensedBold.ttf
          weight: 400

    - family: Arslan
      fonts:
        - asset: assets/font/Arslan.ttf
          weight: 400
    - family: Emoji
      fonts:
        - asset: assets/font/NotoColorEmoji-Regular.ttf
          weight: 400
